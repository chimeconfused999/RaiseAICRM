# Copy this file to ".env" and fill in real values.
# ".env" is gitignored and must NEVER be committed.
#
# On Windows PowerShell you can load these before running:
#   Get-Content .env | ForEach-Object { if ($_ -match '^\s*([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim()) } }

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key

# Bright Data API token (used for LinkedIn / SERP / website scraping)
BRIGHT_DATA_API_TOKEN=your-bright-data-token

# Port the web server listens on (optional, defaults to 7070)
PORT=7070
